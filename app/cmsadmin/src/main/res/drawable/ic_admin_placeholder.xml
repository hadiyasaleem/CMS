<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_admin_placeholder.xml
    Circular person silhouette used as the default/placeholder avatar
    in the ActionBar when no profile photo is available.
    ViewBox: 0 0 24 24
-->
