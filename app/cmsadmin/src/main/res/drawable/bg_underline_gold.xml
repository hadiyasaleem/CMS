<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Transparent body of the button -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/transparent" />
        </shape>
    </item>

    <!-- Gold underline pinned to bottom, 2dp tall -->
    <item
        android:top="-2dp"
        android:left="-2dp"
        android:right="-2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/tertiary_fixed_dim" />
        </shape>
    </item>

</layer-list>