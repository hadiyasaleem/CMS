<?xml version="1.0" encoding="utf-8"?>
<!--
    res/drawable/bg_input_underline.xml
    Replicates the HTML: border-0 border-b border-outline/30
    Bottom border only, transparent fill — mimics the underline input style
    Uses a layer-list: transparent body + 1dp bottom line
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Transparent body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Bottom border line only — outline at ~30% opacity = #4D74777F -->
    <item
        android:top="-2dp"
        android:left="-2dp"
        android:right="-2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#4D74777F" />
        </shape>
    </item>

</layer-list>