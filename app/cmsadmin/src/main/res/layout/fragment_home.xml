<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true"
    tools:context=".fragments.HomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="40dp">

        <!-- ═══════════════════════════════════════
             § 1  WELCOME HEADER
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/tv_section_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INSTITUTIONAL OVERSIGHT"
                android:textSize="10sp"
                android:letterSpacing="0.2"
                android:textColor="@color/on_tertiary_fixed_variant"
                android:fontFamily="@font/public_sans"
                android:textStyle="bold"
                android:paddingBottom="6dp" />

            <TextView
                android:id="@+id/tv_welcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome,\nPrincipal Richards."
                android:textSize="36sp"
                android:lineSpacingMultiplier="1.05"
                android:textColor="@color/primary"
                android:fontFamily="@font/newsreader_regular"
                android:textStyle="bold" />

            <View
                android:layout_width="48dp"
                android:layout_height="3dp"
                android:layout_marginTop="14dp"
                android:background="@color/secondary" />

            <TextView
                android:id="@+id/tv_session"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Session: 2023–2024 · Semester II"
                android:textSize="13sp"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/public_sans"
                android:textStyle="italic" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════
             § 2  STATS BENTO GRID (horizontal scroll)
             ═══════════════════════════════════════ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="8dp">

                <!-- Card 1: Total Students -->
                <androidx.cardview.widget.CardView
                    android:layout_width="200dp"
                    android:layout_height="160dp"
                    android:layout_marginEnd="12dp"
                    app:cardBackgroundColor="@color/surface_container_lowest"
                    app:cardCornerRadius="2dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:alpha="0.08"
                            android:src="@drawable/ic_group"
                            android:contentDescription="@null" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL STUDENTS"
                                android:textSize="9sp"
                                android:letterSpacing="0.15"
                                android:textColor="@color/outline"
                                android:fontFamily="@font/public_sans"
                                android:textStyle="bold"
                                android:paddingBottom="10dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tv_total_students"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2,450"
                                    android:textSize="36sp"
                                    android:textColor="@color/primary"
                                    android:fontFamily="@font/newsreader_bold_italic"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:text="+12%"
                                    android:textSize="11sp"
                                    android:textColor="@color/secondary"
                                    android:fontFamily="@font/public_sans"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentStart="true"
                            android:background="@color/secondary" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 2: Active Faculty (dark) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="200dp"
                    android:layout_height="160dp"
                    android:layout_marginEnd="12dp"
                    app:cardBackgroundColor="@color/primary"
                    app:cardCornerRadius="2dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:alpha="0.10"
                            android:src="@drawable/ic_school"
                            android:contentDescription="@null"
                            app:tint="@color/on_primary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE FACULTY"
                                android:textSize="9sp"
                                android:letterSpacing="0.15"
                                android:textColor="@color/on_primary_container"
                                android:fontFamily="@font/public_sans"
                                android:textStyle="bold"
                                android:paddingBottom="10dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tv_active_faculty"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="120"
                                    android:textSize="36sp"
                                    android:textColor="@color/on_primary"
                                    android:fontFamily="@font/newsreader_bold_italic"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Verified"
                                    android:textSize="11sp"
                                    android:textColor="@color/tertiary_fixed_dim"
                                    android:fontFamily="@font/public_sans"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentStart="true"
                            android:background="@color/tertiary_fixed_dim" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card 3: Pending Requests -->
                <androidx.cardview.widget.CardView
                    android:layout_width="200dp"
                    android:layout_height="160dp"
                    app:cardBackgroundColor="@color/surface_container_low"
                    app:cardCornerRadius="2dp"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentTop="true"
                            android:alpha="0.08"
                            android:src="@drawable/ic_pending_actions"
                            android:contentDescription="@null" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PENDING REQUESTS"
                                android:textSize="9sp"
                                android:letterSpacing="0.15"
                                android:textColor="@color/outline"
                                android:fontFamily="@font/public_sans"
                                android:textStyle="bold"
                                android:paddingBottom="10dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/tv_pending_requests"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="15"
                                    android:textSize="36sp"
                                    android:textColor="@color/secondary"
                                    android:fontFamily="@font/newsreader_bold_italic"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="REQUIRES\nATTENTION"
                                    android:textSize="9sp"
                                    android:letterSpacing="0.08"
                                    android:textColor="@color/secondary"
                                    android:fontFamily="@font/public_sans"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="40dp"
                            android:layout_height="3dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentStart="true"
                            android:background="#4DB22B1D" />

                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ═══════════════════════════════════════
             § 3  RECENT ACADEMIC ALERTS
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Recent Academic Alerts"
                    android:textSize="22sp"
                    android:textColor="@color/primary"
                    android:fontFamily="@font/newsreader_bold"
                    android:textStyle="bold|italic" />

                <TextView
                    android:id="@+id/tv_view_archives"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="VIEW ARCHIVES"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textColor="@color/secondary"
                    android:fontFamily="@font/public_sans"
                    android:textStyle="bold"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_underline_amber" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A74777F"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_alerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_alert" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════
             § 4  COMMAND CENTER
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Command Center"
                android:textSize="22sp"
                android:textColor="@color/primary"
                android:fontFamily="@font/newsreader_bold"
                android:textStyle="bold|italic"
                android:paddingBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1A74777F"
                android:layout_marginBottom="16dp" />

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Add New Student -->
                <LinearLayout
                    android:id="@+id/action_add_student"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/surface_container_low"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_person_add"
                        android:contentDescription="@null"
                        android:layout_marginBottom="10dp"
                        app:tint="@color/secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ONBOARDING"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/public_sans"
                        android:alpha="0.6"
                        android:paddingBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add New Student"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:fontFamily="@font/newsreader_regular"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- View Attendance Report -->
                <LinearLayout
                    android:id="@+id/action_attendance_report"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/surface_container_low"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_analytics"
                        android:contentDescription="@null"
                        android:layout_marginBottom="10dp"
                        app:tint="@color/secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="METRICS"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/public_sans"
                        android:alpha="0.6"
                        android:paddingBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Attendance Report"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:fontFamily="@font/newsreader_regular"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Manage Exams -->
                <LinearLayout
                    android:id="@+id/action_manage_exams"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/surface_container_low"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_edit_calendar"
                        android:contentDescription="@null"
                        android:layout_marginBottom="10dp"
                        app:tint="@color/secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EVALUATION"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/public_sans"
                        android:alpha="0.6"
                        android:paddingBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage Exams"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:fontFamily="@font/newsreader_regular"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- System Utilities -->
                <LinearLayout
                    android:id="@+id/action_system_utilities"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/surface_container_low"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_settings_suggest"
                        android:contentDescription="@null"
                        android:layout_marginBottom="10dp"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONFIGURATION"
                        android:textSize="9sp"
                        android:letterSpacing="0.12"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/public_sans"
                        android:alpha="0.6"
                        android:paddingBottom="3dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="System Utilities"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface"
                        android:fontFamily="@font/newsreader_regular"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ═══════════════════════════════════════
             § 5  ACADEMIC INTEGRITY NOTICE (amber banner)
             ═══════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_integrity_banner"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_verified_user"
                    android:contentDescription="@null"
                    android:layout_marginEnd="8dp"
                    app:tint="@color/on_tertiary_fixed_variant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Academic Integrity Notice"
                    android:textSize="15sp"
                    android:textColor="@color/on_tertiary_fixed"
                    android:fontFamily="@font/newsreader_bold"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_integrity_notice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The end-of-term audit is scheduled for next Monday. Ensure all ledger entries are synchronized before 17:00 HRS."
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.5"
                android:textColor="@color/on_tertiary_fixed_variant"
                android:fontFamily="@font/public_sans" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>