<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_splash.xml  — REWRITTEN v2
    Matches screen.png exactly:
    ✔ Top bar: bank icon + "The Academic Ledger" bold italic serif + version + green dot
    ✔ Seal: rounded-square CardView (not circle), large bank icon inside
    ✔ Eyebrow: "THE ACADEMIC LEDGER" amber/gold spaced caps
    ✔ College name: very large bold serif, multi-line centered
    ✔ Tagline: italic serif centered, gold short dashes on left & right sides
    ✔ Chip: "ADMIN CONTROL CENTER" pill (surface-container-high bg)
    ✔ Login button: full-width dark navy with arrow-right icon on end
    ✔ "Request Access Credentials" text with gold underline
    ✔ Progress bar (thin, red-orange) + status label
    ✔ Footer: shield + "AUTHENTICATED ACCESS ONLY" + copyright
    ✔ Decorative blob top-right
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/surface"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/splashRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="680dp">

        <!-- ── Decorative blob top-right corner ─────────────────────── -->
        <View
            android:id="@+id/accentTopRight"
            android:layout_width="170dp"
            android:layout_height="210dp"
            android:background="@drawable/bg_accent_top_right"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════════════════
             TOP APP BAR
             bank icon | "The Academic Ledger" (bold italic serif) | v2.0.4-LTS | green dot
             ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="46dp"
            android:paddingBottom="14dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_account_balance"
                android:tint="@color/primary"
                android:contentDescription="@string/cd_logo"
                android:layout_marginEnd="9dp" />

            <!-- Italic bold serif — "The Academic Ledger" -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/top_bar_title"
                android:textSize="17sp"
                android:fontFamily="@font/newsreader_bold_italic"
                android:textColor="@color/primary" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_version"
                android:textSize="10sp"
                android:fontFamily="@font/public_sans_semibold"
                android:textColor="@color/on_surface_variant"
                android:letterSpacing="0.1"
                android:layout_marginEnd="8dp" />

            <!-- Green live dot -->
            <View
                android:id="@+id/liveDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_live_dot" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════
             SEAL CARD — rounded square (16dp corners), large bank icon
             ═══════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/sealCard"
            android:layout_width="170dp"
            android:layout_height="170dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <ImageView
                    android:id="@+id/sealIcon"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@drawable/ic_account_balance"
                    android:tint="@color/primary"
                    android:contentDescription="@string/cd_college_seal" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════════
             EYEBROW — "THE ACADEMIC LEDGER" in amber/gold
             ═══════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/labelEyebrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ledger_eyebrow"
            android:textSize="12sp"
            android:letterSpacing="0.22"
            android:textAllCaps="true"
            android:fontFamily="@font/public_sans_semibold"
            android:textColor="@color/on_tertiary_fixed_variant"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/sealCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════════════════
             COLLEGE NAME — very large bold serif, centered, multi-line
             ═══════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvCollegeName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Govt Graduate College, Mandi Bahauddin"
            android:textSize="40sp"
            android:lineSpacingMultiplier="1.1"
            android:fontFamily="@font/newsreader_bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelEyebrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════════════════
             TAGLINE ROW
             [gold dash 28dp]  [italic tagline centered]  [gold dash 28dp]
             ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/taglineRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/tvCollegeName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Left gold dash -->
            <View
                android:layout_width="28dp"
                android:layout_height="2dp"
                android:background="@color/tertiary_fixed_dim"
                android:layout_marginEnd="16dp" />

            <!-- Italic tagline, fills remaining space -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/college_tagline"
                android:textSize="17sp"
                android:fontFamily="@font/newsreader_italic"
                android:textColor="@color/on_surface_variant"
                android:gravity="center" />

            <!-- Right gold dash -->
            <View
                android:layout_width="28dp"
                android:layout_height="2dp"
                android:background="@color/tertiary_fixed_dim"
                android:layout_marginStart="16dp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════
             "ADMIN CONTROL CENTER" pill chip
             ═══════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/chipAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_admin_control"
            android:textSize="11sp"
            android:letterSpacing="0.18"
            android:textAllCaps="true"
            android:fontFamily="@font/public_sans_semibold"
            android:textColor="@color/on_surface_variant"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:background="@drawable/bg_chip_rounded"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/taglineRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════════════════
             LOGIN AS ADMIN — full-width dark navy button, arrow-right icon
             Hidden (gone) when admin is already logged in
             ═══════════════════════════════════════════════════════════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLoginAdmin"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:text="@string/btn_login_admin"
            android:textSize="16sp"
            android:fontFamily="@font/public_sans_semibold"
            android:textColor="@color/on_primary"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="18dp"
            android:visibility="gone"
            app:backgroundTint="@color/primary"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_login"
            app:iconTint="@color/on_primary"
            app:iconGravity="end"
            app:iconPadding="10dp"
            app:iconSize="20dp"
            app:layout_constraintTop_toBottomOf="@id/chipAdmin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════════════════
             "Request Access Credentials" — gold underline text link
             Hidden until login button is shown
             ═══════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/tvRequestAccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_request_access"
            android:textSize="14sp"
            android:fontFamily="@font/public_sans_semibold"
            android:textColor="@color/on_surface"
            android:visibility="gone"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_underline_gold"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/btnLoginAdmin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ═══════════════════════════════════════════════════════════
             BOTTOM FOOTER BLOCK (pinned to bottom via barrier)
             progress bar → status label → divider → shield + auth text → copyright
             ═══════════════════════════════════════════════════════════ -->

        <!-- Barrier sits below whichever of these is taller -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/contentBarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tvRequestAccess,chipAdmin" />

        <LinearLayout
            android:id="@+id/footerBlock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="28dp"
            android:paddingBottom="28dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            app:layout_constraintTop_toBottomOf="@id/contentBarrier"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="1.0">

            <!-- Thin progress bar, 160dp wide, red-orange fill -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="160dp"
                android:layout_height="2dp"
                android:indeterminate="false"
                android:progress="33"
                android:max="100"
                android:progressTint="@color/secondary_container"
                android:progressBackgroundTint="@color/surface_container_highest"
                android:layout_marginBottom="8dp" />

            <!-- "INITIALIZING SECURE PORTAL…" status -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_initializing"
                android:textSize="9sp"
                android:letterSpacing="0.12"
                android:textAllCaps="true"
                android:fontFamily="@font/public_sans_semibold"
                android:textColor="@color/outline"
                android:layout_marginBottom="22dp" />

            <!-- Thin horizontal rule -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/outline_variant"
                android:alpha="0.35"
                android:layout_marginBottom="18dp" />

            <!-- Shield icon + "AUTHENTICATED ACCESS ONLY" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="5dp">

                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_verified_user"
                    android:tint="@color/primary"
                    android:alpha="0.55"
                    android:contentDescription="@string/cd_verified_shield"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/footer_auth_only"
                    android:textSize="9sp"
                    android:letterSpacing="0.18"
                    android:textAllCaps="true"
                    android:fontFamily="@font/public_sans_semibold"
                    android:textColor="@color/on_surface_variant"
                    android:alpha="0.55" />
            </LinearLayout>

            <!-- "© 2024 Institutional Ledger Systems" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/footer_copyright_full"
                android:textSize="10sp"
                android:fontFamily="@font/public_sans"
                android:textColor="@color/on_surface_variant"
                android:alpha="0.55" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>